# Copy this file to .env and fill in real provider keys.
#
# Default mode: SmartVoice can stay mock while eKYC uses real VNPT credentials.
# Per-product modes override VNPT_PROVIDER_MODE when set.
#
# Recommended:
#   VNPT_EKYC_MODE=real
#   VNPT_SMARTVOICE_MODE=real
VNPT_PROVIDER_MODE=mock
VNPT_EKYC_MODE=real
VNPT_SMARTVOICE_MODE=real
VNPT_BASE_URL=https://api.idg.vnpt.vn
# Shared fallback credentials (used when product-specific vars are empty).
VNPT_ACCESS_TOKEN=
VNPT_TOKEN_ID=
VNPT_TOKEN_KEY=
# eKYC-only header auth (overrides shared vars for face/liveness/mask/compare).
VNPT_EKYC_ACCESS_TOKEN=
VNPT_EKYC_TOKEN_ID=
VNPT_EKYC_TOKEN_KEY=
# SmartVoice-only header auth (overrides shared vars for STT).
VNPT_SMARTVOICE_ACCESS_TOKEN=
VNPT_SMARTVOICE_TOKEN_ID=
VNPT_SMARTVOICE_TOKEN_KEY=
# Optional JSON body "token" for eKYC face endpoints (not the same as Token-id header).
VNPT_EKYC_TOKEN=
VNPT_MAC_ADDRESS=TEST1
VNPT_STT_SAMPLE_RATE=16000
VNPT_STT_CONTENT_TYPE=audio/wav
VNPT_STT_ENABLE_LM=true
VNPT_STT_BIT_PER_RATE=16
VNPT_STT_DOMAIN=general
VNPT_STT_SAVE_LOG=true
VNPT_STT_CAP_PUNCT_RECOVERY=true

# Legacy placeholders for product-specific adapters.
VNPT_SMARTVOICE_API_KEY=
VNPT_SMARTBOT_API_KEY=
VNPT_SMARTREADER_API_KEY=

# Local development defaults.
FIDES_ENV=development

# Neo4j — Grow trust graph (docker compose up neo4j -d)
NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=fides-dev-password
